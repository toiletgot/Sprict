loadstring([[
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local VIM = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local enabled = false
local running = true
local touchingScreen = false

local interval = 0
local burstCount = 20

local mode = "RANDOM"
local targetPos = nil
local selecting = false

local minX, maxX = 0.7, 0.95
local minY, maxY = 0.3, 0.8

local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 200, 0, 230)
frame.Position = UDim2.new(0.7, -100, 0.5, -115)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Parent = gui
Instance.new("UICorner", frame)

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,25)
title.Text = "AUTOCLICK ULTIMATE"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundTransparency = 1
title.Parent = frame

local toggle = Instance.new("TextButton")
toggle.Size = UDim2.new(0.8,0,0,35)
toggle.Position = UDim2.new(0.1,0,0.15,0)
toggle.Text = "OFF"
toggle.BackgroundColor3 = Color3.fromRGB(200,50,50)
toggle.TextColor3 = Color3.new(1,1,1)
toggle.Parent = frame
Instance.new("UICorner", toggle)

local modeBtn = Instance.new("TextButton")
modeBtn.Size = UDim2.new(0.8,0,0,30)
modeBtn.Position = UDim2.new(0.1,0,0.35,0)
modeBtn.Text = "Mode: RANDOM"
modeBtn.Parent = frame
Instance.new("UICorner", modeBtn)

local setBtn = Instance.new("TextButton")
setBtn.Size = UDim2.new(0.8,0,0,25)
setBtn.Position = UDim2.new(0.1,0,0.52,0)
setBtn.Text = "位置を指定"
setBtn.Parent = frame
Instance.new("UICorner", setBtn)

local inputBox = Instance.new("TextBox")
inputBox.Size = UDim2.new(0.5,0,0,25)
inputBox.Position = UDim2.new(0.1,0,0.7,0)
inputBox.PlaceholderText = "速度(0=最速)"
inputBox.BackgroundColor3 = Color3.fromRGB(50,50,50)
inputBox.TextColor3 = Color3.new(1,1,1)
inputBox.Parent = frame
Instance.new("UICorner", inputBox)

local plus = Instance.new("TextButton")
plus.Size = UDim2.new(0.15,0,0,25)
plus.Position = UDim2.new(0.65,0,0.7,0)
plus.Text = "+"
plus.Parent = frame
Instance.new("UICorner", plus)

local minus = Instance.new("TextButton")
minus.Size = UDim2.new(0.15,0,0,25)
minus.Position = UDim2.new(0.82,0,0.7,0)
minus.Text = "-"
minus.Parent = frame
Instance.new("UICorner", minus)

local close = Instance.new("TextButton")
close.Size = UDim2.new(0,20,0,20)
close.Position = UDim2.new(1,-22,0,2)
close.Text = "❌"
close.BackgroundColor3 = Color3.fromRGB(255,60,60)
close.TextColor3 = Color3.new(1,1,1)
close.Parent = frame
Instance.new("UICorner", close)

toggle.MouseButton1Click:Connect(function()
	enabled = not enabled
	toggle.Text = enabled and "ON" or "OFF"
	toggle.BackgroundColor3 = enabled and Color3.fromRGB(50,200,50) or Color3.fromRGB(200,50,50)
end)

modeBtn.MouseButton1Click:Connect(function()
	mode = (mode == "RANDOM") and "AIM" or "RANDOM"
	modeBtn.Text = "Mode: "..mode
end)

setBtn.MouseButton1Click:Connect(function()
	selecting = true
	setBtn.Text = "タップして設定"
end)

UIS.InputBegan:Connect(function(input, gpe)
	if input.UserInputType == Enum.UserInputType.Touch then
		if not gpe then touchingScreen = true end
		if selecting then
			targetPos = input.Position
			selecting = false
			setBtn.Text = "設定OK"
		end
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		touchingScreen = false
	end
end)

inputBox.FocusLost:Connect(function()
	local num = tonumber(inputBox.Text)
	if num then interval = math.max(0, num) end
end)

plus.MouseButton1Click:Connect(function()
	interval = math.max(0, interval - 0.002)
	inputBox.Text = tostring(interval)
end)

minus.MouseButton1Click:Connect(function()
	interval = interval + 0.002
	inputBox.Text = tostring(interval)
end)

close.MouseButton1Click:Connect(function()
	enabled = false
	running = false
	gui:Destroy()
end)

local function click()
	local size = camera.ViewportSize
	for i = 1, burstCount do
		if mode == "AIM" and targetPos then
			local ox = math.random(-3,3)
			local oy = math.random(-3,3)
			VIM:SendMouseButtonEvent(targetPos.X+ox, targetPos.Y+oy, 0, true, game, 0)
			VIM:SendMouseButtonEvent(targetPos.X+ox, targetPos.Y+oy, 0, false, game, 0)
		else
			local x = size.X * (minX + math.random() * (maxX - minX))
			local y = size.Y * (minY + math.random() * (maxY - minY))
			VIM:SendMouseButtonEvent(x,y,0,true,game,0)
			VIM:SendMouseButtonEvent(x,y,0,false,game,0)
		end
	end
end

task.spawn(function()
	while running do
		if enabled and not touchingScreen then click() end
		if interval <= 0 then task.wait() else task.wait(interval) end
	end
end)

local dragging = false
local startPos, startFramePos

title.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		startPos = input.Position
		startFramePos = frame.Position
	end
end)

title.InputEnded:Connect(function() dragging = false end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.Touch then
		local delta = input.Position - startPos
		frame.Position = UDim2.new(
			startFramePos.X.Scale,
			startFramePos.X.Offset + delta.X,
			startFramePos.Y.Scale,
			startFramePos.Y.Offset + delta.Y
		)
	end
end)
]])()
