local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local player = Players.LocalPlayer

local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")

-- メインフレーム
local mainFrame = Instance.new("Frame")
mainFrame.Parent = screenGui
mainFrame.Size = UDim2.new(0, 100, 0, 150)
mainFrame.Position = UDim2.new(1, -110, 1, -160)
mainFrame.BackgroundColor3 = Color3.fromRGB(25,25,25)
mainFrame.BorderSizePixel = 0
mainFrame.ClipsDescendants = true

-- ドラッグバー
local dragBar = Instance.new("TextLabel")
dragBar.Parent = mainFrame
dragBar.Size = UDim2.new(1, -44, 0, 22) -- 右にボタン用スペース
dragBar.BackgroundColor3 = Color3.fromRGB(80,80,80)
dragBar.TextColor3 = Color3.new(1,1,1)
dragBar.TextScaled = true
dragBar.TextTruncate = Enum.TextTruncate.AtEnd
dragBar.Text = player.Name
dragBar.BorderSizePixel = 0
dragBar.Active = true

-- 閉じるボタン
local closeButton = Instance.new("TextButton")
closeButton.Parent = mainFrame
closeButton.Size = UDim2.new(0, 22, 0, 22)
closeButton.Position = UDim2.new(1, -22, 0, 0)
closeButton.BackgroundColor3 = Color3.fromRGB(170,0,0)
closeButton.TextColor3 = Color3.new(1,1,1)
closeButton.TextScaled = true
closeButton.Text = "×"
closeButton.BorderSizePixel = 0
closeButton.MouseButton1Click:Connect(function()
	screenGui:Destroy()
end)

-- 最小化ボタン
local minButton = Instance.new("TextButton")
minButton.Parent = mainFrame
minButton.Size = UDim2.new(0, 22, 0, 22)
minButton.Position = UDim2.new(1, -44, 0, 0)
minButton.BackgroundColor3 = Color3.fromRGB(100,100,100)
minButton.TextColor3 = Color3.new(1,1,1)
minButton.TextScaled = true
minButton.Text = "−"
minButton.BorderSizePixel = 0

local isMinimized = false
minButton.MouseButton1Click:Connect(function()
	isMinimized = not isMinimized
	if isMinimized then
		mainFrame.Size = UDim2.new(0, 100, 0, 22) -- ドラッグバーだけ残す
	else
		mainFrame.Size = UDim2.new(0, 100, 0, 150)
	end
end)

-- スクロール部分
local scrollFrame = Instance.new("ScrollingFrame")
scrollFrame.Parent = mainFrame
scrollFrame.Position = UDim2.new(0,0,0,22)
scrollFrame.Size = UDim2.new(1,0,1,-22)
scrollFrame.CanvasSize = UDim2.new(0,0,0,0)
scrollFrame.ScrollBarImageTransparency = 0.4
scrollFrame.BackgroundTransparency = 1
scrollFrame.BorderSizePixel = 0

local layout = Instance.new("UIListLayout")
layout.Parent = scrollFrame
layout.Padding = UDim.new(0,2)

layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
	scrollFrame.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
end)

-- ドラッグ
local dragging = false
local dragStart
local startPos

dragBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 
	or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position
	end
end)

UserInputService.InputEnded:Connect(function(input)
	dragging = false
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging then
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

-- プレイヤーボタン
local function createButton(targetPlayer)
	if targetPlayer == player then return end
	
	local button = Instance.new("TextButton")
	button.Parent = scrollFrame
	button.Size = UDim2.new(1, -4, 0, 20)
	button.BackgroundColor3 = Color3.fromRGB(50,50,50)
	button.TextColor3 = Color3.new(1,1,1)
	button.TextScaled = true
	button.TextTruncate = Enum.TextTruncate.AtEnd
	button.Text = targetPlayer.Name
	button.BorderSizePixel = 0
	
	button.MouseButton1Click:Connect(function()
		if targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
			player.Character.HumanoidRootPart.CFrame =
				targetPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,-3)
		end
	end)
end

for _, plr in pairs(Players:GetPlayers()) do
	createButton(plr)
end

Players.PlayerAdded:Connect(createButton)
