-- 5. UI更新
local function updateUI()
    for i=1, 6 do spinButtons[i].BackgroundColor3 = (activeSpin == i) and ACTIVE_GREEN or DARK end
    for i=10, 12 do spinButtons[i].BackgroundColor3 = (activeSpin == i) and Color3.fromRGB(80, 45, 90) or DARK end
    spinButtons[7].BackgroundColor3 = targetFollowActive and ACTIVE_GREEN or DARK
    spinButtons[8].BackgroundColor3 = sineMoveActive and ACTIVE_GREEN or DARK 
    spinButtons[9].BackgroundColor3 = noForceActive and Color3.fromRGB(120, 80, 40) or DARK
    
    ModeFrame.Visible = sineMoveActive
    local isSineOnly = sineMoveActive and (activeSpin == 0)
    if isSineOnly then SpeedInput.Text = tostring(moveStuds); TimeInput.Text = string.format("%.1f", moveFrequency); SpeedDown.BackgroundColor3 = PINK_BTN; SpeedUp.BackgroundColor3 = BLUE_BTN; TimeDown.BackgroundColor3 = PINK_BTN; TimeUp.BackgroundColor3 = BLUE_BTN else SpeedInput.Text = tostring(displaySpeed); TimeInput.Text = string.format("%.1f", teleportInterval); SpeedDown.BackgroundColor3 = RED_BTN; SpeedUp.BackgroundColor3 = GREEN_BTN; TimeDown.BackgroundColor3 = RED_BTN; TimeUp.BackgroundColor3 = GREEN_BTN end
    FixButton.Text = isLocked and "FIX: ON" or "FIX: OFF"; FixButton.BackgroundColor3 = isLocked and Color3.fromRGB(120, 80, 40) or DARK; NoclipButton.Text = noclipActive and "NOCLIP: ON" or "NOCLIP: OFF"; NoclipButton.BackgroundColor3 = noclipActive and ACTIVE_GREEN or DARK; ESPButton.Text = espEnabled and "ESP: ON" or "ESP: OFF"; ESPButton.BackgroundColor3 = espEnabled and ACTIVE_GREEN or DARK
end

-- 6. メインループ
RunService.Stepped:Connect(function()
    if noclipActive or targetFollowActive or sineMoveActive then
        local char = player.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end
        end
    end
end)

RunService.Heartbeat:Connect(function(dt)
    local char = player.Character; local hrp = char and char:FindFirstChild("HumanoidRootPart"); local hum = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end
    
    if isLocked and lockPosition and not sineMoveActive then hrp.Velocity = Vector3.new(0,0,0); hrp.CFrame = CFrame.new(lockPosition) * hrp.CFrame.Rotation end

    if activeSpin > 0 or targetFollowActive or sineMoveActive then
        for _, anim in pairs(hum:GetPlayingAnimationTracks()) do anim:Stop() end
        angle = (angle + (displaySpeed / 10)) % 360; local cp, baseRotation = hrp.Position, hrp.CFrame.Rotation
        local rv = noForceActive and 0 or (displaySpeed * 200)

        if targetFollowActive then
            if not currentTargetPlayer or not currentTargetPlayer.Character or not currentTargetPlayer.Character:FindFirstChild("HumanoidRootPart") or (tick() - lastTargetSwitchTime >= teleportInterval) then 
                local plrs = {}; for _,v in pairs(game.Players:GetPlayers()) do if v~=player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then table.insert(plrs, v) end end 
                currentTargetPlayer = #plrs > 0 and plrs[math.random(1,#plrs)] or nil; lastTargetSwitchTime = tick() 
            end
            if currentTargetPlayer and currentTargetPlayer.Character then 
                local tHRP = currentTargetPlayer.Character:FindFirstChild("HumanoidRootPart") 
                if tHRP then cp = tHRP.Position; baseRotation = tHRP.CFrame.Rotation; if cameraPart and currentTargetPlayer.Character:FindFirstChild("Head") then cameraPart.CFrame = currentTargetPlayer.Character.Head.CFrame end end 
            end
        elseif sineMoveActive and spin8OriginCF then
            currentPhase = currentPhase + (dt * moveFrequency); local t = currentPhase * (math.pi * 2)
            if moveMode == "Linear" then cp = spin8OriginCF.Position + (spin8OriginCF.LookVector * math.sin(t) * moveStuds); baseRotation = spin8OriginCF.Rotation
            elseif moveMode == "Circle" then cp = spin8OriginCF.Position + (spin8OriginCF.RightVector * math.cos(t) * moveStuds) + (spin8OriginCF.LookVector * math.sin(t) * moveStuds); baseRotation = spin8OriginCF.Rotation
            elseif moveMode == "Thwomp" then
                local cyc = currentPhase % 1; local alpha = (cyc < 0.8) and (math.sin(cyc * (math.pi / 0.8))) or (-10 * (cyc - 0.8))
                cp = (spin8OriginCF.Position - Vector3.new(0, 2, 0)) + Vector3.new(0, moveStuds * alpha, 0); baseRotation = spin8OriginCF.Rotation * CFrame.Angles(math.rad(-90), 0, 0)
                if cyc > 0.8 then hrp.Velocity = Vector3.new(0, -800, 0) end
            end
        end

        -- 回転ロジック (1-12)
        if activeSpin == 1 then hrp.CFrame = CFrame.new(cp) * CFrame.Angles(0, math.rad(angle), 0); hrp.RotVelocity = Vector3.new(0, rv, 0)
        elseif activeSpin == 2 and lockedCFrames[2] then hrp.CFrame = CFrame.new(cp) * lockedCFrames[2].Rotation * CFrame.Angles(0,0,math.rad(angle)); hrp.RotVelocity = hrp.CFrame.LookVector * rv
        elseif activeSpin == 3 and lockedCFrames[3] then hrp.CFrame = CFrame.new(cp) * lockedCFrames[3].Rotation * CFrame.Angles(math.rad(angle),0,0); hrp.RotVelocity = hrp.CFrame.RightVector * rv
        elseif activeSpin == 4 and lockedCFrames[4] then hrp.CFrame = CFrame.new(cp) * lockedCFrames[4].Rotation * CFrame.Angles(math.rad(-90),0,math.rad(angle)); hrp.RotVelocity = hrp.CFrame.LookVector * rv
        elseif activeSpin == 5 and lockedCFrames[5] then hrp.CFrame = CFrame.new(cp) * lockedCFrames[5].Rotation * CFrame.Angles(math.rad(90),math.rad(angle),0); hrp.RotVelocity = Vector3.new(0, rv, 0)
        elseif activeSpin == 6 then local fDir = GetMoveDirection(); hrp.CFrame = CFrame.new(cp, cp+fDir) * CFrame.Angles(math.rad(80), math.rad(angle), math.rad(angle)); hrp.RotVelocity = Vector3.new(rv, rv, rv)
        elseif activeSpin == 10 then -- Chaos Axis
            hrp.CFrame = CFrame.new(cp) * CFrame.Angles(math.rad(angle*1.5), math.rad(angle*0.8), math.rad(angle*2.1))
            hrp.RotVelocity = Vector3.new(rv, rv, rv)
        elseif activeSpin == 11 then -- Star Spin
            local step = math.floor(angle / 72) * 72
            hrp.CFrame = CFrame.new(cp) * CFrame.Angles(0, math.rad(step), 0)
            hrp.RotVelocity = Vector3.new(0, rv * 2, 0)
        elseif activeSpin == 12 then -- Vertical Hurricane
            hrp.CFrame = CFrame.new(cp) * CFrame.Angles(math.rad(angle), 0, math.rad(90))
            hrp.RotVelocity = hrp.CFrame.RightVector * rv
        else 
            hrp.CFrame = CFrame.new(cp) * baseRotation 
            if not noForceActive then hrp.RotVelocity = Vector3.new(0, rv, 0) end
        end
    end
end)

