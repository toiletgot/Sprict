-- (他のUIパーツも同様に配置... ロジックに集中するためボタン動作へ)

local function updateUI()
    for i=1, 12 do
        if i <= 6 then spinButtons[i].BackgroundColor3 = (activeSpin == i) and ACTIVE_GREEN or DARK
        elseif i >= 10 then spinButtons[i].BackgroundColor3 = (activeSpin == i) and Color3.fromRGB(80, 45, 90) or DARK end
    end
    spinButtons[7].BackgroundColor3 = targetFollowActive and ACTIVE_GREEN or DARK
    spinButtons[8].BackgroundColor3 = sineMoveActive and ACTIVE_GREEN or DARK
    spinButtons[9].BackgroundColor3 = noForceActive and Color3.fromRGB(120, 80, 40) or DARK
    FixButton.Text = isLocked and "FIX: ON" or "FIX: OFF"; FixButton.BackgroundColor3 = isLocked and Color3.fromRGB(120, 80, 40) or DARK
    SpeedInput.Text = tostring(displaySpeed)
end

-- 5. メインループ
RunService.Heartbeat:Connect(function(dt)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not hrp or not hum then return end

    -- いずれの機能もオフなら物理をリセットして抜ける
    if activeSpin == 0 and not targetFollowActive and not sineMoveActive then
        if not isLocked and hrp.RotVelocity.Magnitude > 0.1 then
            hrp.RotVelocity = Vector3.new(0,0,0)
        end
        return 
    end

    -- ロジック開始
    angle = (angle + (displaySpeed / 10)) % 360
    local cp = hrp.Position
    local baseRotation = hrp.CFrame.Rotation
    local rv = noForceActive and 0 or (displaySpeed * 200)

    -- ターゲット追従
    if targetFollowActive then
        if not currentTargetPlayer or (tick() - lastTargetSwitchTime >= teleportInterval) then
            local plrs = {}
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then table.insert(plrs, v) end
            end
            currentTargetPlayer = #plrs > 0 and plrs[math.random(1, #plrs)] or nil
            lastTargetSwitchTime = tick()
        end
        if currentTargetPlayer and currentTargetPlayer.Character then
            local tHRP = currentTargetPlayer.Character:FindFirstChild("HumanoidRootPart")
            if tHRP then cp = tHRP.Position; baseRotation = tHRP.CFrame.Rotation end
        end
    end

    -- 回転適用
    if activeSpin == 1 then
        hrp.CFrame = CFrame.new(cp) * CFrame.Angles(0, math.rad(angle), 0)
        hrp.RotVelocity = Vector3.new(0, rv, 0)
    elseif activeSpin == 2 and lockedCFrames[2] then
        hrp.CFrame = CFrame.new(cp) * lockedCFrames[2].Rotation * CFrame.Angles(0,0,math.rad(angle))
        hrp.RotVelocity = hrp.CFrame.LookVector * rv
    -- (他のSpin番号も同様)
    else
        hrp.CFrame = CFrame.new(cp) * baseRotation
        hrp.RotVelocity = Vector3.new(0, rv, 0)
    end
end)

-- 6. 各種イベント
for i = 1, 12 do
    spinButtons[i].MouseButton1Click:Connect(function()
        if activeSpin == i then 
            FullStop() 
        else 
            activeSpin = i
            if i >= 2 and i <= 5 then lockedCFrames[i] = CFrame.new(Vector3.new(), GetMoveDirection()) end
        end
        updateUI()
    end)
end

FixButton.MouseButton1Click:Connect(function()
    isLocked = not isLocked
    if isLocked then 
        lockPosition = player.Character.HumanoidRootPart.Position 
    else 
        FullStop() 
    end
    updateUI()
end)

