local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")
local camera = workspace.CurrentCamera
local CoreGui = game:GetService("CoreGui")

-- 1. 変数定義
local activeSpin = 0
local targetFollowActive = false
local sineMoveActive = false
local noForceActive = false
local espEnabled = false
local isLocked = false
local noclipActive = true
local moveMode = "Linear"

local displaySpeed = 300
local moveStuds = 10
local moveFrequency = 2.0
local teleportInterval = 1.8
local angle = 0
local currentPhase = 0
local spin8OriginCF = nil
local lockPosition = nil
local cameraPart = nil
local lockedCFrames = {}
local currentTargetPlayer = nil
local lastTargetSwitchTime = 0

local DARK = Color3.fromRGB(45, 45, 45)
local ACTIVE_GREEN = Color3.fromRGB(45, 90, 45)
local PINK_BTN = Color3.fromRGB(255, 105, 180)
local BLUE_BTN = Color3.fromRGB(0, 100, 255)

-- 2. ヘルパー関数
local function GetMoveDirection()
    local char = player.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum and hum.MoveDirection.Magnitude > 0 then return hum.MoveDirection.Unit end
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then 
        local f = hrp.CFrame.LookVector
        return Vector3.new(f.X, 0, f.Z).Unit 
    end
    return Vector3.new(0, 0, 1)
end

local function ClearCameraPart()
    if cameraPart then cameraPart:Destroy(); cameraPart = nil end
    local hum = player.Character and player.Character:FindFirstChild("Humanoid")
    if hum then 
        camera.CameraType = Enum.CameraType.Custom
        camera.CameraSubject = hum 
    end
end

-- 3. 停止・復元ロジック (最重要)
local function RecoverCharacter()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if hrp then
        hrp.Velocity = Vector3.new(0, 0, 0)
        hrp.RotVelocity = Vector3.new(0, 0, 0)
    end
    if hum then
        hum.PlatformStand = false
        hum:ChangeState(Enum.HumanoidStateType.Running)
    end
end

local function FullStop()
    activeSpin = 0
    targetFollowActive = false
    sineMoveActive = false
    isLocked = false
    lockPosition = nil
    RecoverCharacter()
    ClearCameraPart()
    -- UI更新は下で行う
end

