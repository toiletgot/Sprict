-- 3. ヘルパー関数
local function GetMoveDirection() local char = player.Character; local hum = char and char:FindFirstChild("Humanoid") if hum and hum.MoveDirection.Magnitude > 0 then return hum.MoveDirection.Unit end; local hrp = char and char:FindFirstChild("HumanoidRootPart") if hrp then local f = hrp.CFrame.LookVector; return Vector3.new(f.X, 0, f.Z).Unit end; return Vector3.new(0, 0, 1) end
local function RecoverCharacter() local char = player.Character; local hrp = char and char:FindFirstChild("HumanoidRootPart"); local hum = char and char:FindFirstChild("Humanoid") if hrp and hum then hrp.Velocity = Vector3.new(0, 0, 0); hrp.RotVelocity = Vector3.new(0, 0, 0); local moveDir = GetMoveDirection(); hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + moveDir); hum:ChangeState(Enum.HumanoidStateType.Running); hum.PlatformStand = false end end
local function ClearCameraPart() if cameraPart then cameraPart:Destroy(); cameraPart = nil end; local hum = player.Character and player.Character:FindFirstChild("Humanoid") if hum then camera.CameraType = Enum.CameraType.Custom; camera.CameraSubject = hum end end
local function CreateCameraPart() if sineMoveActive then return end; ClearCameraPart(); local part = Instance.new("Part"); part.Transparency = 1; part.CanCollide = false; part.Anchored = true; part.Size = Vector3.new(1,1,1); part.Parent = workspace; cameraPart = part; camera.CameraSubject = cameraPart end
local function CreateFixedCameraPart(pos) ClearCameraPart(); local p = Instance.new("Part"); p.Transparency = 1; p.CanCollide = false; p.Anchored = true; p.Size = Vector3.new(1,1,1); p.CFrame = CFrame.new(pos); p.Parent = workspace; cameraPart = p; camera.CameraSubject = cameraPart end

