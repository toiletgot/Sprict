local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")

local localPlayer = Players.LocalPlayer
local camera = workspace.CurrentCamera

local selectedPlayer = nil
local enabled = false
local zoomDistance = 1.3

-- 回転
local rotX = 0
local rotY = 0

-- ズーム長押し
local zoomingIn = false
local zoomingOut = false

-- ===== タッチ視点操作 =====
UIS.InputChanged:Connect(function(input)
	if not enabled then return end
	if input.UserInputType == Enum.UserInputType.Touch then
		rotX = rotX - input.Delta.X * 0.6
		rotY = math.clamp(rotY - input.Delta.Y * 0.6, -80, 80)
	end
end)

-- ===== GUI =====
local gui = Instance.new("ScreenGui", game.CoreGui)

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0,120,0,200)
frame.Position = UDim2.new(0,10,0,100)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Parent = gui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,-50,0,25)
title.Text = "Player"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundTransparency = 1
title.Parent = frame

-- ===== ドラッグ =====
local dragging = false
local dragStart, startPos

title.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
	end
end)

title.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

title.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.Touch then
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

-- ===== プレイヤー一覧 =====
local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1,0,1,-65)
scroll.Position = UDim2.new(0,0,0,45)
scroll.BackgroundTransparency = 1
scroll.Parent = frame

local layout = Instance.new("UIListLayout", scroll)

local emptyLabel = Instance.new("TextLabel")
emptyLabel.Size = UDim2.new(1,0,0,20)
emptyLabel.Text = "いません"
emptyLabel.TextColor3 = Color3.new(1,1,1)
emptyLabel.BackgroundTransparency = 1
emptyLabel.Visible = false
emptyLabel.Parent = scroll

local function updateList()
	for _, v in pairs(scroll:GetChildren()) do
		if v:IsA("TextButton") then v:Destroy() end
	end
	
	local count = 0
	for _, p in pairs(Players:GetPlayers()) do
		if p ~= localPlayer then
			count += 1
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1,0,0,20)
			btn.Text = p.Name
			btn.TextColor3 = Color3.new(1,1,1)
			btn.BackgroundColor3 = Color3.fromRGB(50,50,50)
			btn.Parent = scroll
			
			btn.MouseButton1Click:Connect(function()
				selectedPlayer = p
				for _, b in pairs(scroll:GetChildren()) do
					if b:IsA("TextButton") then
						b.BackgroundColor3 = Color3.fromRGB(50,50,50)
					end
				end
				btn.BackgroundColor3 = Color3.fromRGB(0,170,255)
			end)
		end
	end
	
	emptyLabel.Visible = (count == 0)
	scroll.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
end

updateList()
Players.PlayerAdded:Connect(updateList)
Players.PlayerRemoving:Connect(updateList)

-- ===== ズーム =====
local zoomIn = Instance.new("TextButton")
zoomIn.Size = UDim2.new(0.5,0,0,20)
zoomIn.Position = UDim2.new(0,0,0,25)
zoomIn.Text = "+"
zoomIn.Parent = frame

local zoomOut = Instance.new("TextButton")
zoomOut.Size = UDim2.new(0.5,0,0,20)
zoomOut.Position = UDim2.new(0.5,0,0,25)
zoomOut.Text = "-"
zoomOut.Parent = frame

zoomIn.MouseButton1Down:Connect(function() zoomingIn = true end)
zoomIn.MouseButton1Up:Connect(function() zoomingIn = false end)
zoomOut.MouseButton1Down:Connect(function() zoomingOut = true end)
zoomOut.MouseButton1Up:Connect(function() zoomingOut = false end)

-- ===== ON/OFF =====
local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(1,0,0,20)
toggleBtn.Position = UDim2.new(0,0,1,-20)
toggleBtn.Text = "OFF"
toggleBtn.Parent = frame

toggleBtn.MouseButton1Click:Connect(function()
	enabled = not enabled
	if enabled then
		toggleBtn.Text = "ON"
	else
		toggleBtn.Text = "OFF"
		camera.CameraType = Enum.CameraType.Custom
		if localPlayer.Character then
			camera.CameraSubject = localPlayer.Character:FindFirstChildOfClass("Humanoid")
		end
	end
end)

-- ===== 閉じる（完全終了）=====
local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0,25,0,25)
closeBtn.Position = UDim2.new(1,-25,0,0)
closeBtn.Text = "×"
closeBtn.Parent = frame

closeBtn.MouseButton1Click:Connect(function()
	enabled = false
	camera.CameraType = Enum.CameraType.Custom
	if localPlayer.Character then
		camera.CameraSubject = localPlayer.Character:FindFirstChildOfClass("Humanoid")
	end
	gui:Destroy()
end)

-- ===== 最小化/復元 =====
local minimizeBtn = Instance.new("TextButton")
minimizeBtn.Size = UDim2.new(0,25,0,25)
minimizeBtn.Position = UDim2.new(1,-50,0,0)
minimizeBtn.Text = "_"
minimizeBtn.Parent = frame

local minimized = false
minimizeBtn.MouseButton1Click:Connect(function()
	if not minimized then
		-- 最小化
		frame.Size = UDim2.new(0,100,0,30)
		scroll.Visible = false
		zoomIn.Visible = false
		zoomOut.Visible = false
		toggleBtn.Visible = false
		minimized = true
	else
		-- 復元
		frame.Size = UDim2.new(0,120,0,200)
		scroll.Visible = true
		zoomIn.Visible = true
		zoomOut.Visible = true
		toggleBtn.Visible = true
		minimized = false
	end
end)

-- ===== カメラ更新 =====
RunService.RenderStepped:Connect(function()
	if zoomingIn then zoomDistance = math.max(0.5, zoomDistance - 0.3) end
	if zoomingOut then zoomDistance = zoomDistance + 0.3 end
	
	if not enabled or not selectedPlayer then return end
	local char = selectedPlayer.Character
	if not char then return end
	local head = char:FindFirstChild("Head")
	if not head then return end
	
	camera.CameraType = Enum.CameraType.Scriptable
	local rotation = CFrame.Angles(0, math.rad(rotX), 0) * CFrame.Angles(math.rad(rotY), 0, 0)
	local offset = rotation.LookVector * zoomDistance
	local targetPos = head.Position + Vector3.new(0,0.5,0)
	camera.CFrame = CFrame.new(targetPos - offset, targetPos)
end)
